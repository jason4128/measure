rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'name', 'data', 'updatedAt']) && 
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 && data.name.size() > 0 &&
             data.data is string && data.data.size() <= 1000000 &&
             data.updatedAt == request.time;
    }

    match /projects/{projectId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) && 
                    existing().userId == incoming().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'updatedAt']);
      allow delete: if isSignedIn() && isValidId(projectId) && existing().userId == request.auth.uid;
    }
  }
}
